# Time complexcity:O(R-L+1)
L=3
R=5
ans=0
for i in range(L,R+1):
    ans=ans^i
    
print(ans)    

# Time complexcity:O(1)
# ṣpace compelxcity:O(1)
# if they ask in interms of N
def xor(num):
    if num%4==1:
        return 1
    elif num%4==2:
        return num+1
    elif num%4==3:
        return 0
    else:
        return num 
    
res=xor(8) 
print(res)   

# They may ask follow up Question-- L-R range

def xor1(l,r):
    return xor(l-1)^xor(r)

l=3
r=7
res=xor1(l,r)
print(res)